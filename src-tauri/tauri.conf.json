{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FileWhisper",
  "version": "0.1.0",
  "identifier": "com.filewhisper.app",
  "build": {
    "beforeDevCommand": "FILEWHISPER_PORT=8001 python3 server_launcher.py",
    "beforeBuildCommand": "",
    "frontendDist": "../static",
    "devUrl": "http://127.0.0.1:8001"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../dist/filewhisper-backend*"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
